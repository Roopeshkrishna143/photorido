# For Development

NODE_ENV=development
PORT=5000
API_PREFIX=/api
MONGODB_URI=mongodb://127.0.0.1:27017/photorido
FRONTEND_URL=http://localhost:3000
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret-at-least-32-characters
AUTH_COOKIE_NAME=photorido_auth_token
REFRESH_COOKIE_NAME=photorido_refresh_token
ACCESS_TOKEN_TTL_HOURS=24
REFRESH_TOKEN_TTL_DAYS=30
BCRYPT_SALT_ROUNDS=12
JSON_BODY_LIMIT=20mb
GOOGLE_CLIENT_ID=1019466949240-k366pgduhv77p2pr5km92pllh4ftflj7.apps.googleusercontent.com
# VITE_GOOGLE_CLIENT_ID="1019466949240-k366pgduhv77p2pr5km92pllh4ftflj7.apps.googleusercontent.com"

GOOGLE_MAPS_API_KEY=
MAILTRAP_API_URL=https://send.api.mailtrap.io/api/send
MAILTRAP_API_TOKEN=
MAILTRAP_SENDER_EMAIL=
MAILTRAP_SENDER_NAME=Photorido
OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_MOBILE_TEST_RECIPIENT_EMAIL=
ALLOW_PUBLIC_REGISTRATION=true

